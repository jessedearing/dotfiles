format = """[вЦУвЦТвЦС](fg:#769ff0 bg:#394260)\
${custom.jj}${custom.jjstate}[оВі](fg:#394260)\n\
[вЦСвЦТвЦУ](#a3aed2)\
{{- if eq .chezmoi.os "linux" }}
[ у∞£З ](bg:#a3aed2 fg:#363fa0)\
{{- else }}
[ оЬС ](bg:#a3aed2 fg:#090c0c)\
{{- end }}
$directory\
[оВі](fg:#769ff0 bg:#394260)\
$nodejs\
$rust\
$golang\
$php\
[оВі](fg:#212736 bg:#1d2230)\
$time\
$kubernetes\
[оВі ](fg:#1d2230)\
\n$character"""

command_timeout = 900

right_format = """[оВґ](fg:#779FF0)$jobs[вЦУвЦТвЦС](fg:#769ff0 bg:#394260)"""

[kubernetes]
disabled = false
symbol = "у±ГЊ "
style = "bg:#212736"
format = '[[$symbol$context( \($namespace\))](fg:#769ff0 bg:#212736)]($style)'

[aws]
symbol = "пГВ  "
style = "blue"

[jobs]
symbol = " пСС "

[directory]
style = "fg:#e3e5e5 bg:#769ff0"
format = "[ $path ]($style)"
truncation_length = 3
truncation_symbol = "вА¶/"

[directory.substitutions]
"Documents" = "у∞ИЩ "
"Downloads" = "пАЩ "
"Music" = "пАБ "
"Pictures" = "пАЊ "

[git_branch]
disabled = true
symbol = "пРШ"
style = "bg:#394260"
format = '[[ $symbol $branch ](fg:#769ff0 bg:#394260)]($style)'

[git_status]
disabled = true
style = "bg:#394260"
format = '[[($all_status$ahead_behind )](fg:#769ff0 bg:#394260)]($style)'

[nodejs]
symbol = "оЬШ"
style = "bg:#212736"
format = '[[ $symbol ($version) ](fg:#769ff0 bg:#212736)]($style)'

[golang]
symbol = "оШІ"
style = "bg:#212736"
format = '[[ $symbol ($version) ](fg:#769ff0 bg:#212736)]($style)'

[time]
disabled = false
time_format = "%R"                                      # Hour:Minute Format
style = "bg:#1d2230"
format = '[[ пРЇ $time ](fg:#a0a9cb bg:#1d2230)]($style)'

[custom.jj]
ignore_timeout = true
description = "The current jj status"
detect_folders = [".jj"]
symbol = "рЯ•Л "
command = '''
jj log --revisions @ --no-graph --ignore-working-copy --color always --limit 1 --template '
  separate(" ",
    change_id.shortest(4),
    bookmarks,
    "|",
    concat(
      if(conflict, "рЯТ•"),
      if(divergent, "рЯЪІ"),
      if(hidden, "рЯСї"),
      if(immutable, "рЯФТ"),
    ),
    raw_escape_sequence("\x1b[1;32m") ++ if(empty, "(empty)"),
    raw_escape_sequence("\x1b[1;32m") ++ coalesce(
      truncate_end(29, description.first_line(), "вА¶"),
      "(no description set)",
    ) ++ raw_escape_sequence("\x1b[0m"),
  )
'
'''

[custom.jjstate]
when = "jj root"
command = '''
jj log -r@ -n1 --no-graph -T "" --stat | tail -n1 | sd "(\d+) files? changed, (\d+) insertions?\(\+\), (\d+) deletions?\(-\)" ' ${1}m ${2}+ ${3}-' | sd " 0." ""
'''
